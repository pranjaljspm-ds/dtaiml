create a basic responsive webpage using bootstrap using components like navigation, bars, buttons, and forms

<!DOCTYPE html>
<html>
<head>
<title>Bootstrap Page</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-light bg-light">
  <div class="container">
    <span class="navbar-brand">my website</span>
  </div>
</nav>

<!-- Content -->
<div class="container mt-3">
  <h3>Welcome</h3>
  <p>Simple Bootstrap page.</p>
  <button class="btn btn-primary btn-sm">Click</button>
</div>

<!-- Form -->
<div class="container mt-3">
  <form>
    <input class="form-control mb-2" placeholder="Name">
    <input class="form-control mb-2" placeholder="Email">
    <textarea class="form-control mb-2" placeholder="Message"></textarea>
    <button class="btn btn-success btn-sm">Submit</button>
  </form>
</div>

<!-- Footer -->
<footer class="bg-dark text-white text-center mt-3 p-2">
  <small>© 2025 My Site</small>
</footer>

</body>
</html>
