DEVELOP A SMALL WEB APPLICATION WITH A USIN LOGIN PAGE USING BOOTSTRAP

<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="d-flex justify-content-center align-items-center vh-100">

<div class="card p-3" style="width:250px;">
    <h5 class="text-center">Login</h5>

    <form onsubmit="return validate()">
        <input type="email" id="email" class="form-control mb-2" placeholder="Email">
        <input type="password" id="pass" class="form-control mb-2" placeholder="Password">
        <button class="btn btn-primary w-100 btn-sm">Login</button>
    </form>
</div>

<script>
function validate(){
    let e = document.getElementById("email").value;
    let p = document.getElementById("pass").value;
    if(e=="" || p==""){
        alert("Fill all fields");
        return false;
    }
    return true;
}
</script>

</body>
</html>
